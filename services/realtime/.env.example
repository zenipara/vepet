# Server
PORT=4001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:password@localhost:5432/vetcare

# JWT (for validating tokens from API Gateway)
JWT_SECRET=your-super-secret-jwt-key

# Service Auth (from API Gateway)
SERVICE_AUTH_TOKEN=your-service-auth-token

# Realtime Config
WS_PATH=/ws
MAX_MESSAGE_SIZE=65536
